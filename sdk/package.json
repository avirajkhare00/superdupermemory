{
  "name": "superdupermemory",
  "version": "0.1.1",
  "description": "TypeScript SDK for superdupermemory — local-first memory layer for AI agents",
  "keywords": ["memory", "ai", "agents", "mcp", "llm"],
  "license": "Apache-2.0",
  "author": "Aviraj Khare <avirajkhare00@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/avirajkhare00/superdupermemory",
    "directory": "sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
